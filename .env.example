# HormuzWatch — Environment Variables
# Copy this file to .env and fill in your keys
# Get all keys for FREE — see README.md for links

# EIA API (https://www.eia.gov/opendata/)
EIA_API_KEY=your_eia_key_here

# Alpha Vantage (https://www.alphavantage.co/support/#api-key)
ALPHA_VANTAGE_API_KEY=your_alpha_vantage_key_here

# FRED - Federal Reserve (https://fred.stlouisfed.org/docs/api/api_key.html)
FRED_API_KEY=your_fred_key_here

# NewsAPI (https://newsapi.org/register)
NEWS_API_KEY=your_newsapi_key_here

# Supabase (https://supabase.com — free tier)
SUPABASE_URL=your_supabase_project_url
SUPABASE_KEY=your_supabase_anon_key

# Supabase DIRECT POSTGRES CONNECTION — separate from SUPABASE_URL/KEY above,
# needed only for the dbt warehouse (dbt/). Get these from: Supabase dashboard
# -> Project Settings -> Database -> Connection string. Leave unset to skip
# the warehouse build (run_pipeline.py's dbt step no-ops if these aren't set).
SUPABASE_DB_HOST=db.your-project-ref.supabase.co
SUPABASE_DB_PORT=5432
SUPABASE_DB_USER=postgres
SUPABASE_DB_PASSWORD=your_db_password
SUPABASE_DB_NAME=postgres

# Slack incoming webhook — optional, enables DAG failure alerts (run_pipeline.py).
# Create one at https://api.slack.com/messaging/webhooks. Leave unset to skip alerting.
SLACK_WEBHOOK_URL=your_slack_incoming_webhook_url

# JWT signing key for the API (api/main.py) — REQUIRED for any real deployment.
# Without it, a random key is generated per process start, invalidating all
# issued tokens on restart. Generate one with: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET_KEY=your_random_secret_key_here

# Gemini API (https://aistudio.google.com/apikey) — free tier. Enables the
# "Ask HormuzWatch" RAG assistant, structured news extraction, evals, and the
# agentic daily briefing (genai/). Leave unset to skip all of Layer 6 — every
# genai/ script no-ops gracefully without it.
GEMINI_API_KEY=your_gemini_api_key_here

# No key needed for: World Bank API, GDELT
